# Pi Agent VSCode Extension - Environment Configuration
# Copy this file to .env and edit as needed.

# LLM API Configuration
# Base URL for OpenAI-compatible API (e.g., 9router, Ollama, LM Studio)
PI_API_BASE_URL=http://localhost:8080/v1
PI_API_KEY=
PI_API_MODEL=versatile

# Subagent Models
WORKER_MODEL=coder
SCOUT_MODEL=assistant
RESEARCHER_MODEL=reason

# Subagent Settings
SUBAGENTS_MAX_CONCURRENCY=4

# Inline Suggestions
PI_INLINE_SUGGESTIONS_ENABLED=false
